{
    "expo": {
        "name": "Sweet Paradise",
        "slug": "SweetParadise",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/sweet.jpg",
        "splash": {
            "image": "./assets/cake.jpg",
            "resizeMode": "contain",
            "backgroundColor": "#FFFFFF"
        },
        "userInterfaceStyle": "light",
        "assetBundlePatterns": [
            "assets/database/*.db",
            "assets/images/*"
        ],
        "ios": {
            "supportsTablet": true,
            "infoPlist": {
                "NSCameraUsageDescription": "Разрешите доступ к камере для установки фото профиля",
                "NSPhotoLibraryUsageDescription": "Разрешите доступ к галерее для выбора фото профиля"
            }
        },
        "android": {
            "icon": "./assets/sweet.jpg",
            "package": "com.victoria007.SweetParadise",
            "permissions": [
                "android.permission.CAMERA",
                "android.permission.READ_EXTERNAL_STORAGE",
                "android.permission.WRITE_EXTERNAL_STORAGE"
            ]
        },
        "web": {
            "favicon": "./assets/favicon.png"
        },
        "extra": {
            "eas": {
                "projectId": "3906c2d9-df6e-4658-9ed5-07b50c90a4fe"
            }
        }
    }
}